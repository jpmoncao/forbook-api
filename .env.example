NODE_ENV=development

### Database
DATABASE_URL=

### API
PEPPER_SECRET=
JWT_SECRET=

### Email
EMAIL_FROM=
FRONTEND_LOGIN_URL=

# Desenvolvimento — Mailtrap Email Sandbox (API, não SMTP)
# Token: https://mailtrap.io/api-tokens | Inbox ID: número na URL (ex.: .../inboxes/2564102/...)
MAILTRAP_API_KEY=
MAILTRAP_INBOX_ID=

# Produção — SendGrid Web API
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

### Firebase Admin
FIREBASE_CONFIG_PATH=./firebase.json
FIREBASE_STORAGE_BUCKET=